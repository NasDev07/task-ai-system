################################################################################
# AI SALES PAGE GENERATOR - ENVIRONMENT CONFIGURATION
# Copy this file to .env and update values for your environment
# Generated: April 28, 2026
################################################################################

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application name displayed in UI and emails
APP_NAME="AI Sales Page Generator"

# Environment: local, staging, production
APP_ENV=local

# Generate with: php artisan key:generate
# IMPORTANT: Do NOT commit .env with actual keys to version control
APP_KEY=base64:xxxxx

# Enable debug mode (MUST be false in production)
APP_DEBUG=true

# Base URL of your application
APP_URL=http://localhost:8000

# Application locale settings
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database driver: mysql, postgres, sqlite, sqlserver
DB_CONNECTION=mysql

# Database host - use 127.0.0.1 for local, not 'localhost'
DB_HOST=127.0.0.1

# Database port (3306 for MySQL)
DB_PORT=3306

# Database name - same as created in migration step
DB_DATABASE=laravel_db

# Database user - usually 'root' for local development
DB_USERNAME=root

# Database password - leave empty if no password set locally
DB_PASSWORD=

# ============================================================================
# GOOGLE GEMINI AI CONFIGURATION
# CRITICAL: Required for sales page generation feature
# ============================================================================

# Get your free API key from: https://aistudio.google.com/apikey
# Quota: Free tier usually allows sufficient requests for testing
GEMINI_API_KEY=your_gemini_api_key_here

# Model version to use - latest recommended for best results
# Options: gemini-1.5-pro, gemini-1.5-flash, gemini-3-flash-preview
GEMINI_MODEL=gemini-3-flash-preview

# ============================================================================
# SESSION & AUTHENTICATION CONFIGURATION
# ============================================================================

# Session storage driver: database, file, cookie, array
SESSION_DRIVER=database

# Session timeout in minutes (120 = 2 hours)
SESSION_LIFETIME=120

# Encrypt session data (recommended for production)
SESSION_ENCRYPT=false

# Session cookie path
SESSION_PATH=/

# Session cookie domain (leave null for current domain)
SESSION_DOMAIN=null

# ============================================================================
# CACHE & QUEUE CONFIGURATION
# ============================================================================

# Cache driver: database, file, redis, memcached, array
CACHE_STORE=database

# Cache key prefix (optional)
# CACHE_PREFIX=

# Queue driver: database, sync, redis, beanstalk, sqs
QUEUE_CONNECTION=database

# ============================================================================
# MAIL CONFIGURATION
# ============================================================================

# Mail driver: smtp, sendmail, mailgun, ses, postmark, log
MAIL_MAILER=log

# For SMTP configuration
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

# Sender email and name
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log channel: single, stack, daily, slack, stderr, syslog
LOG_CHANNEL=stack

# Log stack layers (multiple channels)
LOG_STACK=single

# Log level: debug, info, notice, warning, error, critical, alert, emergency
LOG_LEVEL=debug

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Bcrypt password hashing rounds (higher = slower but more secure)
BCRYPT_ROUNDS=12

# Maintenance mode driver: file, database
APP_MAINTENANCE_DRIVER=file

# ============================================================================
# BROADCAST CONFIGURATION
# ============================================================================

# Broadcast driver: pusher, redis, log, null
BROADCAST_CONNECTION=log

# ============================================================================
# FILESYSTEM CONFIGURATION
# ============================================================================

# Filesystem disk: local, public, s3
FILESYSTEM_DISK=local

# ============================================================================
# REDIS CONFIGURATION (if using Redis for cache/queue)
# ============================================================================

# Redis client: phpredis, predis
REDIS_CLIENT=phpredis

# Redis server host
REDIS_HOST=127.0.0.1

# Redis server port
REDIS_PORT=6379

# Redis authentication password
REDIS_PASSWORD=null

# ============================================================================
# MEMCACHED CONFIGURATION (if using Memcached)
# ============================================================================

# Memcached server host
MEMCACHED_HOST=127.0.0.1

# ============================================================================
# AWS S3 CONFIGURATION (for file storage in production)
# ============================================================================

# AWS Access Key ID (get from AWS IAM)
AWS_ACCESS_KEY_ID=

# AWS Secret Access Key (keep secure, never commit)
AWS_SECRET_ACCESS_KEY=

# AWS region
AWS_DEFAULT_REGION=us-east-1

# S3 bucket name
AWS_BUCKET=

# Use path-style endpoints for S3 (for S3-compatible services)
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================================
# VITE BUILD CONFIGURATION (Frontend assets)
# ============================================================================

# Application name for frontend
VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# ADDITIONAL SETTINGS
# ============================================================================

# Maintenance store (when using database driver)
# APP_MAINTENANCE_STORE=database

# PHP CLI server workers (for php artisan serve)
# PHP_CLI_SERVER_WORKERS=4

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 
# 1. INITIAL SETUP:
#    cp .env.example .env
#    php artisan key:generate
#
# 2. CONFIGURE LOCALLY:
#    Update DB_* variables with your local database credentials
#    Update GEMINI_API_KEY with your API key
#
# 3. PRODUCTION SETUP:
#    - Change APP_ENV to 'production'
#    - Change APP_DEBUG to 'false'
#    - Update APP_URL to your domain
#    - Use strong database passwords
#    - Configure proper mail settings (SMTP)
#    - Setup Redis/Memcached for better performance
#    - Use AWS S3 for file storage
#
# 4. VERIFY SETUP:
#    php artisan config:cache
#    php artisan migrate --seed
#    php artisan serve
#
# ============================================================================
